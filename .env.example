# Copy this file to .env and fill in your own values.

# --- PostgreSQL (admin user — used by ETL; can write/DROP) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here
PG_DATABASE=olist_db

# --- PostgreSQL (read-only user — used by the agent and dashboard) ---
# Defence-in-depth: even if the SQL guardrail had a bug, this DB role
# only has SELECT permission — no INSERT/UPDATE/DELETE/DROP at the role
# level. Create it once with:
#   psql -U postgres -d olist_db -f src/seed_readonly_user.sql
# If left blank, the project falls back to PG_USER (dev mode).
PG_USER_AGENT=olist_agent
PG_PASSWORD_AGENT=change_me_to_a_strong_value

# --- Groq (free tier; sign up at https://console.groq.com) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- CORS (comma-less JSON array, e.g. '["http://localhost:8501"]') ---
# CORS_ORIGINS=["*"]
