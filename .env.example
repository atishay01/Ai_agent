# Copy this file to .env and fill in your own values.

# --- PostgreSQL ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here
PG_DATABASE=olist_db

# --- Groq (free tier; sign up at https://console.groq.com) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- CORS (comma-less JSON array, e.g. '["http://localhost:8501"]') ---
# CORS_ORIGINS=["*"]
