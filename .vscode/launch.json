{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run ETL",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/etl.py",
            "cwd": "${workspaceFolder}/src",
            "console": "integratedTerminal"
        },
        {
            "name": "Start Streamlit",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "${workspaceFolder}/src/app.py"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
